{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elianchyndale.github.io/financial-ai-contracts/v1/benchmark-case.schema.json",
  "title": "BenchmarkCase",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "question",
    "question_type",
    "answerable",
    "gold_answer",
    "document_ids",
    "gold_evidence_ids",
    "abstention_expected",
    "unanswerable_reasons",
    "split",
    "synthetic"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "case_id": { "$ref": "#/$defs/identifier" },
    "question": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "question_type": {
      "enum": [
        "factual",
        "comparison",
        "temporal",
        "numerical",
        "conflict",
        "unanswerable"
      ]
    },
    "answerable": { "type": "boolean" },
    "gold_answer": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["text", "numeric_value", "unit", "currency"],
          "properties": {
            "text": { "type": "string", "minLength": 1, "maxLength": 5000 },
            "numeric_value": {
              "type": ["string", "null"],
              "pattern": "^-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$"
            },
            "unit": {
              "type": ["string", "null"],
              "enum": [
                null,
                "currency",
                "percent",
                "basis_points",
                "ratio",
                "years",
                "text"
              ]
            },
            "currency": {
              "type": ["string", "null"],
              "pattern": "^[A-Z]{3}$"
            }
          }
        }
      ]
    },
    "document_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "gold_evidence_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/identifier" }
    },
    "abstention_expected": { "type": "boolean" },
    "unanswerable_reasons": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    },
    "split": { "enum": ["train", "dev", "test"] },
    "synthetic": { "type": "boolean" }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    }
  }
}

