{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://elianchyndale.github.io/financial-ai-contracts/v1/valuation-scenario.schema.json",
  "title": "ValuationScenario",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "scenario_id",
    "bond_id",
    "currency",
    "valuation_date",
    "face_value",
    "base_yield",
    "spread_adjustment_bps",
    "cash_flows",
    "present_value",
    "duration_years",
    "convexity_years2",
    "z_spread_bps",
    "assumptions"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "scenario_id": { "$ref": "#/$defs/identifier" },
    "bond_id": { "$ref": "#/$defs/identifier" },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "valuation_date": { "type": "string", "format": "date" },
    "face_value": { "$ref": "#/$defs/nonNegativeDecimal" },
    "base_yield": { "$ref": "#/$defs/signedDecimal" },
    "spread_adjustment_bps": {
      "type": "integer",
      "minimum": -100000,
      "maximum": 100000
    },
    "cash_flows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["payment_date", "amount"],
        "properties": {
          "payment_date": { "type": "string", "format": "date" },
          "amount": { "$ref": "#/$defs/nonNegativeDecimal" }
        }
      }
    },
    "present_value": { "$ref": "#/$defs/nonNegativeDecimal" },
    "duration_years": { "$ref": "#/$defs/nonNegativeDecimal" },
    "convexity_years2": { "$ref": "#/$defs/nonNegativeDecimal" },
    "z_spread_bps": {
      "type": "integer",
      "minimum": -100000,
      "maximum": 100000
    },
    "assumptions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{2,127}$"
    },
    "nonNegativeDecimal": {
      "type": "string",
      "pattern": "^(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$"
    },
    "signedDecimal": {
      "type": "string",
      "pattern": "^-?(?:0|[1-9][0-9]*)(?:\\.[0-9]+)?$"
    }
  }
}

